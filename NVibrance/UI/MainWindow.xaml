<!-- File: `NVibrance/UI/MainWindow.xaml` -->
<Window x:Class="NVibrance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="NVibrance"
        Width="1100"
        Height="730"
        MinWidth="980"
        MinHeight="730"
        WindowStartupLocation="CenterScreen"
        Background="#0F1115"
        Foreground="#E7EAF0"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False" 
        Icon="pack://application:,,,/ui/Assets/logo.ico">
    
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#151922" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#232A3A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#AAB2C5" />
        <CornerRadius x:Key="CardCorner">12</CornerRadius>
        <Thickness x:Key="CardPadding">18</Thickness>

        <SolidColorBrush x:Key="TitleBarBrush" Color="#151922" />
        <SolidColorBrush x:Key="TitleBarHoverBrush" Color="#1D2330" />
        <SolidColorBrush x:Key="TitleBarPressedBrush" Color="#111521" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#3A1F28" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HeaderText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SubtleText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- App-wide default button style -->
        <Style x:Key="AppButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Background" Value="#273149" />
            <Setter Property="BorderBrush" Value="#36415E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E7EAF0" />
        </Style>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource AppButtonStyle}" />

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="#0F1115" />
            <Setter Property="BorderBrush" Value="#2A3246" />
            <Setter Property="Foreground" Value="#E7EAF0" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="BorderBrush" Value="#2A3246" />
            <Setter Property="Foreground" Value="#E7EAF0" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>

        <DataTemplate x:Key="IconNameTemplate">
            <DockPanel LastChildFill="True">
                <Image Width="16"
                       Height="16"
                       Margin="0,0,8,0"
                       DockPanel.Dock="Left"
                       Source="{Binding Icon}" />
                <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
            </DockPanel>
        </DataTemplate>

        <!-- Caption button styles (do NOT inherit app button styling) -->
        <Style x:Key="TitleBarButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#E7EAF0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource TitleBarHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource TitleBarPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="{StaticResource CardBorderBrush}"
            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom themed title bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="8,0,8,0">
                    <Image Source="pack://application:,,,/ui/Assets/logo.ico"
                           Width="16" Height="16" Margin="0,0,0,0" />
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Margin="12,0,10,0"
                               FontWeight="Bold"
                               Text="NVibrance" />
                </StackPanel>

                <Border Grid.Column="1" Background="Transparent" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Minimize (U+E921) -->
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE921;"
                            Click="Minimize_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                    <!-- Close (U+E8BB) -->
                    <Button Style="{StaticResource CloseTitleBarButtonStyle}"
                            Content="&#xE8BB;"
                            Margin="6,0,0,0"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="NVibrance" FontSize="22" FontWeight="Bold" />
                        <TextBlock Style="{StaticResource SubtleText}"
                                   Text="Profiles activate automatically when an application gains focus." />
                    </StackPanel>
                </Grid>
                
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCorner}"
                            Padding="{StaticResource CardPadding}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource HeaderText}" Text="Profiles" />

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Profiles}"
                                     SelectedItem="{Binding SelectedProfile}"
                                     ItemTemplate="{StaticResource IconNameTemplate}" />

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Rename"
                                        Margin="0"
                                        Padding="10,6"
                                        Click="RenameProfile_Click" />
                                <Button Content="Delete"
                                        Margin="10,0,0,0"
                                        Padding="10,6"
                                        Click="DeleteProfile_Click" />
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Profile vibrance" FontWeight="SemiBold" />
                                <Slider Minimum="{Binding SliderMin}"
                                        Maximum="{Binding SliderMax}"
                                        Value="{Binding ProfileVibrance, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Style="{StaticResource SubtleText}"
                                           Text="{Binding ProfileVibrance, StringFormat=Value: \{0\}}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCorner}"
                            Padding="{StaticResource CardPadding}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource HeaderText}" Text="Add profile" />

                            <GroupBox Grid.Row="1" Header="Running applications">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0"
                                            Content="Refresh list"
                                            Click="RefreshProcesses_Click"
                                            Margin="0" />

                                    <ListBox Grid.Row="2"
                                             x:Name="ProcessList"
                                             Height="220">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="True">
                                                    <Image Width="16"
                                                           Height="16"
                                                           Margin="0,0,8,0"
                                                           DockPanel.Dock="Left"
                                                           Source="{Binding Icon}" />
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Button Grid.Row="3"
                                            Content="Add selected"
                                            Click="AddSelected_Click" />
                                </Grid>
                            </GroupBox>

                            <Button Grid.Row="2"
                                    Content="Browse .exe…"
                                    Click="BrowseExe_Click" />

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Preview (primary display)" FontWeight="SemiBold" />
                                <Slider Minimum="{Binding SliderMin}"
                                        Maximum="{Binding SliderMax}"
                                        Value="{Binding Vibrance, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Style="{StaticResource SubtleText}"
                                           Text="{Binding Vibrance, StringFormat=Current: \{0\}}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5"
                                       Style="{StaticResource SubtleText}"
                                       Margin="0,12,0,0"
                                       Text="Tip: add a profile, select it, then adjust the slider." />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
